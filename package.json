{
  "name": "animo-saas",
  "version": "2.0.0",
  "private": true,
  "description": "开源私域动画素材管理系统 - Open-source private domain animation asset management system",
  "author": "AnimoSaaS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leoyangx/AnimoSaaS.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "prisma",
    "postgresql",
    "asset-management",
    "saas",
    "animation",
    "private-domain"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "type-check": "tsc --noEmit",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed:multitenant": "npx tsx scripts/migrate-to-multitenant.ts",
    "db:rollback:multitenant": "npx tsx scripts/rollback-migration.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@prisma/client": "6.4.1",
    "axios": "^1.13.6",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "0.475.0",
    "motion": "12.35.2",
    "next": "15.1.7",
    "next-themes": "0.4.4",
    "nodemailer": "6.10.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "9.0.1",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.1",
    "tailwind-merge": "3.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.0.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "22.13.4",
    "@types/nodemailer": "6.4.17",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "9.20.1",
    "eslint-config-next": "15.1.7",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "postcss": "8.5.3",
    "prettier": "^3.8.1",
    "prisma": "6.4.1",
    "tailwindcss": "4.0.8",
    "tsx": "^4.19.0",
    "typescript": "5.7.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
