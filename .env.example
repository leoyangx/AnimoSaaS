# AnimoSaaS Configuration
# Admin credentials (Used for initial setup via /api/admin/init)
ADMIN_PASSWORD="admin_password_123"
JWT_SECRET="your_jwt_secret_key_here"

# Database (Docker default: postgresql://animosaas:animosaas_pass@db:5432/animosaas_db)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# Security (Set to true if using HTTP instead of HTTPS)
DISABLE_SECURE_COOKIE=true

# Brand Configuration (Defaults)
NEXT_PUBLIC_BRAND_NAME="AnimoSaaS"
NEXT_PUBLIC_BRAND_SLOGAN="Professional Animation Asset Library"
NEXT_PUBLIC_FOOTER_TEXT="© 2026 AnimoSaaS. All rights reserved."
