# Database Configuration
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://animosaas:animosaas_pass@localhost:5432/animosaas_db"

# JWT Secret Key
# IMPORTANT: Must be at least 32 characters long
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long-change-this-in-production"

# Admin Password
# IMPORTANT: Must be at least 12 characters with uppercase, lowercase, and numbers
# This password will be used to create the default admin account on first initialization
ADMIN_PASSWORD="SecurePassword123"

# Node Environment
# Options: development, production, test
NODE_ENV="development"

# Multi-Tenant Configuration
# Default tenant name (used during initial migration)
DEFAULT_TENANT_NAME="Default"

# Super Admin Account
# Used to create the super admin account that can manage all tenants
SUPER_ADMIN_EMAIL="superadmin@animosaas.com"
SUPER_ADMIN_PASSWORD="SuperAdmin123!"

# Tenant Identification Mode
# Options: subdomain, path, header
# subdomain: tenant1.animosaas.com
# path: animosaas.com/t/tenant1
# header: X-Tenant-Slug header
TENANT_MODE="path"

# Cookie Security
# Set to "false" in production to enable secure cookies (HTTPS only)
# Set to "true" in development for HTTP testing
DISABLE_SECURE_COOKIE="true"

# Application Configuration
# Base URL of your application (used for email links, etc.)
APP_URL="http://localhost:3000"

# Brand Configuration (Optional)
NEXT_PUBLIC_BRAND_NAME="AnimoSaaS"
NEXT_PUBLIC_BRAND_SLOGAN="Professional Animation Asset Library"
NEXT_PUBLIC_FOOTER_TEXT="© 2026 AnimoSaaS. All rights reserved."

# Storage Configuration (Optional)
# Configure your storage backend (AList, 123 Cloud, etc.)
# STORAGE_TYPE="alist"
# STORAGE_API_URL="https://your-alist-instance.com"
# STORAGE_API_TOKEN="your-alist-token"

# Email Configuration (Optional)
# Configure SMTP for email notifications
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="587"
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASSWORD="your-app-password"
# EMAIL_FROM="AnimoSaaS <noreply@example.com>"

# Rate Limiting (Optional)
# Override default rate limits (requests per window)
# RATE_LIMIT_AUTH_MAX="5"
# RATE_LIMIT_AUTH_WINDOW="900000"  # 15 minutes in ms
# RATE_LIMIT_ADMIN_MAX="100"
# RATE_LIMIT_ADMIN_WINDOW="60000"  # 1 minute in ms
# RATE_LIMIT_DOWNLOAD_MAX="10"
# RATE_LIMIT_DOWNLOAD_WINDOW="60000"

# Logging (Optional)
# LOG_LEVEL="info"  # Options: error, warn, info, debug
# LOG_FILE="logs/app.log"

# Feature Flags (Optional)
# ENABLE_REGISTRATION="true"
# ENABLE_INVITATION_CODES="true"
# ENABLE_EMAIL_NOTIFICATIONS="false"

# Security Headers (Optional)
# ENABLE_HSTS="true"
# ENABLE_CSP="true"

# File Upload Limits (Optional)
# MAX_IMAGE_SIZE="10485760"  # 10MB in bytes
# MAX_VIDEO_SIZE="524288000"  # 500MB in bytes
# MAX_ARCHIVE_SIZE="104857600"  # 100MB in bytes

# Session Configuration (Optional)
# SESSION_TIMEOUT="86400000"  # 24 hours in ms
# REFRESH_TOKEN_TIMEOUT="604800000"  # 7 days in ms

# Development Tools (Optional)
# PRISMA_LOG_QUERIES="false"
# NEXT_TELEMETRY_DISABLED="1"
