generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// System Configuration (used by settings-service.ts)
// ============================================================

model SystemSettings {
  id           String   @id @default("default")
  siteName     String   @default("AnimoSaaS")
  logoUrl      String?
  footerText   String   @default("© 2024 AnimoSaaS. All rights reserved.")
  primaryColor String   @default("#00ff88")
  updatedAt    DateTime @updatedAt
}

model StorageSettings {
  id        String   @id @default("default")
  provider  String   @default("LOCAL") // LOCAL, ALIST, S3
  config    String   @default("{}") // JSON string for provider-specific config
  updatedAt DateTime @updatedAt
}

model SecuritySettings {
  id                String   @id @default("default")
  allowRegistration Boolean  @default(true)
  requireInvitation Boolean  @default(false)
  adminEmail        String?
  updatedAt         DateTime @updatedAt
}

// ============================================================
// Navigation (used by settings-service.ts)
// ============================================================

model Navigation {
  id        String   @id @default(cuid())
  label     String
  icon      String?  @default("Link")
  type      String   @default("MODULE") // MODULE, CATEGORY, EXTERNAL
  value     String // Module ID, Category ID, or External URL
  order     Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Top Navigation (used by db.navigation / lib/types.ts TopNav)
// ============================================================

model TopNav {
  id          String   @id @default(cuid())
  name        String
  targetType  String   @default("INTERNAL") // INTERNAL, EXTERNAL, CATEGORY
  targetValue String
  order       Int      @default(0)
  status      String   @default("active") // active, hidden
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Asset Management
// ============================================================

model AssetCategory {
  id       String          @id @default(cuid())
  name     String
  parentId String?
  parent   AssetCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children AssetCategory[] @relation("CategoryTree")
  order    Int             @default(0)
  status   String          @default("active") // active, hidden
  icon     String?
  assets   Asset[]
  deletedAt DateTime?      // 软删除
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([parentId])
  @@index([status])
  @@index([deletedAt])
}

model Asset {
  id              String         @id @default(cuid())
  title           String
  description     String?
  thumbnail       String?
  categoryId      String?
  assetCategory   AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            String[]       @default([])
  downloadUrl     String
  isDirectDownload Boolean       @default(false)
  storageProvider String         @default("LOCAL")
  downloadCount   Int            @default(0)
  downloadLogs    DownloadLog[]
  deletedAt       DateTime?      // 软删除
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([categoryId])
  @@index([createdAt])
  @@index([downloadCount])
  @@index([title])
  @@index([deletedAt])
}

model DownloadLog {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String?
  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// User Management
// ============================================================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      String    @default("USER") // USER, ADMIN, student
  disabled  Boolean   @default(false)
  lastLogin DateTime?
  ip        String?
  city      String?
  deletedAt DateTime? // 软删除
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([role])
  @@index([disabled])
  @@index([createdAt])
  @@index([deletedAt])
}

// ============================================================
// Invitation Codes
// ============================================================

model InvitationCode {
  id        String   @id @default(cuid())
  code      String   @unique
  status    String   @default("unused") // unused, used
  usedBy    String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// Site Configuration (used by db.config / SiteConfig type)
// ============================================================

model SiteConfig {
  id                       Int      @id @default(autoincrement())
  logo                     String   @default("")
  title                    String   @default("AnimoSaaS")
  slogan                   String   @default("为创作者而生，构建您的私域素材资产")
  footer                   String   @default("© 2024 AnimoSaaS. All Rights Reserved.")
  themeColor               String   @default("#00FF00")
  watermark                String   @default("ANIMOSAAS")

  // Registration & Login
  emailVerificationEnabled Boolean  @default(false)
  smtpHost                 String?
  smtpPort                 Int?
  smtpUser                 String?
  smtpPass                 String?
  smtpFrom                 String?

  // Storage - AList
  alistUrl                 String?
  alistToken               String?
  alistRoot                String?  @default("/")

  // Storage - 123Pan
  pan123Token              String?
  pan123Root               String?  @default("/")

  // Storage - Juhe
  juheUrl                  String?
  juheToken                String?

  // Theme
  primaryColor             String?
  secondaryColor           String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ============================================================
// Admin Operation Logs
// ============================================================

model AdminLog {
  id         String   @id @default(cuid())
  action     String
  adminEmail String
  details    String?
  createdAt  DateTime @default(now())

  @@index([adminEmail])
  @@index([createdAt])
  @@index([action])
}
