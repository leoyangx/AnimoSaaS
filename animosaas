run_panel() {
  detect_compose

  while true; do
    print_banner_panel
    print_menu

    printf "  %b请输入选项编号%b: " "${BOLD}${CYAN}" "${NC}"
    read -r choice </dev/tty

    case "$choice" in
      1)  do_version_check ;;
      2)  do_start ;;
      3)  do_stop ;;
      4)  do_restart ;;
      5)  do_logs ;;
      6)  do_status ;;
      7)  do_change_port ;;
      8)  do_change_domain ;;
      9)  do_change_password ;;
      10) do_https ;;
      11) do_backup ;;
      12) do_restore ;;
      13) do_upgrade ;;
      14) do_reinstall ;;
      15) do_reset ;;
      0|q|Q|exit|quit)
        echo ""
        printf "  %b再见！%b\n\n" "${GREEN}" "${NC}"
        exit 0
        ;;
      *)
        warn "无效选项，请输入 0-15"
        sleep 1
        ;;
    esac
  done
}

# ══════════════════════════════════════════════════════════════
#  CLI ARGUMENT DISPATCH
# ══════════════════════════════════════════════════════════════

cli_dispatch() {
  local cmd="$1"
  detect_compose

  case "$cmd" in
    install)                         run_install ;;
    logs|log|-l|--logs)              do_logs ;;
    status|-s|--status)    echo ""; do_status ;;
    start|up)              echo ""; do_start ;;
    stop|down)             echo ""; do_stop ;;
    restart)               echo ""; do_restart ;;
    upgrade|update)        echo ""; do_upgrade ;;
    backup)                echo ""; do_backup ;;
    restore)               echo ""; do_restore ;;
    reset)                          do_reset ;;
    reinstall)                      do_reinstall ;;
    version|--version|-V)
      printf "  AnimoSaaS v%s\n" "${ANIMOSAAS_VERSION}"
      ;;
    help|--help|-h)
      printf "\n"
      printf "  %bAnimoSaaS%b v%s\n" "${BOLD}" "${NC}" "${ANIMOSAAS_VERSION}"
      printf "  %b多租户私域素材管理平台 — 统一安装 & 管理工具%b\n" "${DIM}" "${NC}"
      printf "\n"
      printf "  %b用法:%b  ./animosaas [命令] [选项]\n" "${BOLD}" "${NC}"
      printf "\n"
      printf "  %b无参数运行:%b\n" "${BOLD}${YELLOW}" "${NC}"
      printf "    首次运行（无 .env）  →  自动进入安装向导\n"
      printf "    已部署（有 .env）    →  进入交互式管理面板\n"
      printf "\n"
      printf "  %b快捷命令:%b\n" "${BOLD}${YELLOW}" "${NC}"
      printf "    %-16s %s\n" "install"    "运行安装向导"
      printf "    %-16s %s\n" "start"      "启动服务"
      printf "    %-16s %s\n" "stop"       "停止服务"
      printf "    %-16s %s\n" "restart"    "重启服务"
      printf "    %-16s %s\n" "status"     "查看服务状态"
      printf "    %-16s %s\n" "logs"       "查看实时日志"
      printf "    %-16s %s\n" "upgrade"    "一键升级项目"
      printf "    %-16s %s\n" "backup"     "备份数据库"
      printf "    %-16s %s\n" "restore"    "恢复数据库备份"
      printf "    %-16s %s\n" "reinstall"  "重新安装（保留数据）"
      printf "    %-16s %s\n" "reset"      "重置系统（危险）"
      printf "    %-16s %s\n" "version"    "查看版本号"
      printf "    %-16s %s\n" "help"       "显示此帮助"
      printf "\n"
      printf "  %b选项:%b\n" "${BOLD}${YELLOW}" "${NC}"
      printf "    %-16s %s\n" "--build-local"  "使用本地 Dockerfile 构建（不拉取预构建镜像）"
      printf "    %-16s %s\n" "--verbose, -v"  "显示详细日志输出"
      printf "\n"
      printf "  %b示例:%b\n" "${BOLD}${YELLOW}" "${NC}"
      printf "    ./animosaas                    # 安装向导 或 管理面板\n"
      printf "    ./animosaas install            # 重新运行安装\n"
      printf "    ./animosaas --build-local      # 本地构建模式\n"
      printf "    ./animosaas logs               # 实时查看日志\n"
      printf "    ./animosaas upgrade             # 一键升级\n"
      printf "\n"
      ;;
    *)
      error "未知命令: $cmd"
      printf "  运行 %b./animosaas help%b 查看可用命令\n" "${BOLD}" "${NC}"
      exit 1
      ;;
  esac
}

# ══════════════════════════════════════════════════════════════
#  MAIN ENTRY
# ══════════════════════════════════════════════════════════════

main() {
  # Parse global flags
  local args=()
  for arg in "$@"; do
    case "$arg" in
      --verbose|-v) VERBOSE=1 ;;
      --build-local) BUILD_LOCAL=1 ;;
      *) args+=("$arg") ;;
    esac
  done

  # CLI argument mode
  if [[ ${#args[@]} -gt 0 ]]; then
    cli_dispatch "${args[0]}"
    exit 0
  fi

  # No arguments: check if first run or already deployed
  if [[ -f .env ]]; then
    # Already deployed → management panel
    run_panel
  else
    # First run → install wizard → deploy → auto enter panel
    run_install
  fi
}

main "$@"
