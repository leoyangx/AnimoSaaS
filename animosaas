# ══════════════════════════════════════════════════════════════
#  DOCKER AUTO-INSTALL
# ══════════════════════════════════════════════════════════════

install_docker() {
  step "Docker" "检测 Docker 环境..."

  if command_exists docker && docker info &>/dev/null 2>&1; then
    local docker_version
    docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null \
      || docker --version | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 \
      || echo "unknown")
    success "Docker 已安装: v${docker_version}"
    return 0
  fi

  if command_exists docker && ! docker info &>/dev/null 2>&1; then
    warn "Docker 已安装但守护进程未运行"
    if [[ "$(uname -s)" == "Linux" ]]; then
      info "正在启动 Docker 守护进程..."
      sudo systemctl start docker 2>/dev/null || true
      sudo systemctl enable docker 2>/dev/null || true
      if docker info &>/dev/null 2>&1; then
        success "Docker 守护进程已启动"
        return 0
      fi
    fi
    fatal "无法启动 Docker 守护进程，请手动启动后重试"
  fi

  # Docker not installed — auto install
  echo ""
  printf "  %b┌──────────────────────────────────────────────────────┐%b\n" "${YELLOW}" "${NC}"
  printf "  %b│  Docker 未安装，将自动安装                          │%b\n" "${YELLOW}" "${NC}"
  printf "  %b│  安装来源: https://get.docker.com                   │%b\n" "${YELLOW}" "${NC}"
  printf "  %b└──────────────────────────────────────────────────────┘%b\n" "${YELLOW}" "${NC}"
  echo ""

  if ! confirm "是否自动安装 Docker？" "y"; then
    echo ""
    printf "  请手动安装 Docker 后重新运行本脚本:\n"
    printf "    %bcurl -fsSL https://get.docker.com | bash%b\n" "${DIM}" "${NC}"
    exit 1
  fi

  spinner_start "正在安装 Docker..."
  if curl -fsSL https://get.docker.com | bash &>/dev/null; then
    spinner_stop
    success "Docker 安装完成"
  else
    spinner_stop
    fatal "Docker 安装失败，请检查网络或手动安装"
  fi

  # Start and enable docker
  sudo systemctl start docker 2>/dev/null || true
  sudo systemctl enable docker 2>/dev/null || true

  # Add current user to docker group
  if [[ "$(id -u)" -ne 0 ]]; then
    sudo usermod -aG docker "$(whoami)" 2>/dev/null || true
    warn "已将当前用户加入 docker 组，如遇权限问题请重新登录终端"
  fi

  success "Docker 环境就绪"
}

# ══════════════════════════════════════════════════════════════
#  PREREQUISITES CHECK
# ══════════════════════════════════════════════════════════════

check_prerequisites() {
  step "预检" "正在检查系统环境..."

  local failed=0

  # ── OS Info ──
  local os_info=""
  if [[ -f /etc/os-release ]]; then
    os_info=$(set +eu; . /etc/os-release 2>/dev/null; echo "${PRETTY_NAME:-${ID:-unknown}}")
  else
    os_info="$(uname -s) $(uname -r)"
  fi
  success "操作系统: ${os_info} ($(uname -m))"

  # ── Docker (with auto-install) ──
  if ! command_exists docker; then
    install_docker
  else
    local docker_version
    docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null \
      || docker --version | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 \
      || echo "unknown")
    if [[ "$docker_version" != "unknown" ]] && ! version_gte "$docker_version" "$MIN_DOCKER"; then
      warn "Docker 版本 ${docker_version}，建议 >= ${MIN_DOCKER}"
    else
      success "Docker: v${docker_version}"
    fi
  fi

  # ── Docker daemon ──
  if ! docker info &>/dev/null 2>&1; then
    error "Docker 守护进程未运行"
    [[ "$(uname -s)" == "Linux" ]] && printf "    尝试: %bsudo systemctl start docker%b\n" "${YELLOW}" "${NC}"
    failed=1
  fi

  # ── Docker Compose ──
  if docker compose version &>/dev/null 2>&1; then
    COMPOSE_CMD="docker compose"
    local compose_ver
    compose_ver=$(docker compose version --short 2>/dev/null \
      || docker compose version | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
    success "Compose: v${compose_ver}"
  elif command_exists docker-compose; then
    COMPOSE_CMD="docker-compose"
    local compose_ver
    compose_ver=$(docker-compose version --short 2>/dev/null || echo "unknown")
    success "Compose: v${compose_ver} (独立版)"
  else
    error "未检测到 Docker Compose"
    failed=1
  fi

  # ── Disk space ──
  # Use multiple strategies: df -P -m, df --output, df -k fallback
  local available_mb=""
  available_mb=$(df -P -m "$(pwd)" 2>/dev/null | awk 'NR==2{print $4}') || true
  if [[ -z "$available_mb" ]] || ! [[ "$available_mb" =~ ^[0-9]+$ ]]; then
    available_mb=$(df --output=avail -BM "$(pwd)" 2>/dev/null | awk 'NR==2{gsub(/M/,""); print $1}') || true
  fi
  if [[ -z "$available_mb" ]] || ! [[ "$available_mb" =~ ^[0-9]+$ ]]; then
    # Final fallback: df -k and convert to MB
    local available_kb=""
    available_kb=$(df -P "$(pwd)" 2>/dev/null | awk 'NR==2{print $4}') || true
    available_kb="${available_kb//[!0-9]/}"
    if [[ -n "$available_kb" ]] && [[ "$available_kb" =~ ^[0-9]+$ ]]; then
      available_mb=$((available_kb / 1024))
    fi
  fi
  available_mb="${available_mb//[!0-9]/}"
  available_mb="${available_mb:-0}"
  if [[ "$available_mb" -lt "$MIN_DISK_MB" ]] 2>/dev/null; then
    warn "磁盘空间不足: 剩余 ${available_mb}MB（建议 >= ${MIN_DISK_MB}MB）"
  else
    local available_gb
    available_gb=$(awk "BEGIN {printf \"%.1f\", ${available_mb}/1024}")
    success "磁盘空间: 剩余 ${available_gb}GB"
  fi

  # ── Memory ──
  local total_mem_mb=0
  if [[ -f /proc/meminfo ]]; then
    total_mem_mb=$(awk '/MemTotal/{printf "%.0f", $2/1024}' /proc/meminfo)
  elif command_exists sysctl; then
    total_mem_mb=$(( $(sysctl -n hw.memsize 2>/dev/null || echo 0) / 1048576 ))
  fi
  if [[ "$total_mem_mb" -gt 0 ]] 2>/dev/null; then
    local total_mem_gb
    total_mem_gb=$(awk "BEGIN {printf \"%.1f\", ${total_mem_mb}/1024}")
    if [[ "$total_mem_mb" -lt 1024 ]]; then
      warn "内存: ${total_mem_gb}GB（建议 >= 1GB）"
    else
      success "内存: ${total_mem_gb}GB"
    fi
  fi

  # ── Port conflicts ──
  local app_port
  app_port=$(read_env_value "APP_PORT")
  app_port="${app_port:-3000}"
  if command_exists ss; then
    ss -tlnp 2>/dev/null | grep -q ":${app_port} " && warn "端口 ${app_port} 已被占用"
  elif command_exists lsof; then
    lsof -i ":${app_port}" &>/dev/null && warn "端口 ${app_port} 已被占用"
  fi

  if [[ "$failed" -ne 0 ]]; then
    echo ""
    fatal "预检未通过，请先解决以上问题后重试。"
  fi
}

