validate_existing_env() {
  step "配置" "正在校验已有 .env 文件..."
  local has_error=0

  local jwt_secret; jwt_secret=$(read_env_value "JWT_SECRET")
  local db_password; db_password=$(read_env_value "DB_PASSWORD")

  if [[ -z "$jwt_secret" ]]; then
    error "缺少 JWT_SECRET"; has_error=1
  elif [[ ${#jwt_secret} -lt 32 ]]; then
    error "JWT_SECRET 长度不足（当前 ${#jwt_secret} 字符，需要 >= 32）"; has_error=1
  else
    success "JWT_SECRET: 合法"
  fi

  if [[ -z "$db_password" ]]; then
    warn "DB_PASSWORD 未设置，将使用 docker-compose 默认值"
  else
    success "DB_PASSWORD: 已设置"
  fi

  [[ "$has_error" -eq 1 ]] && { echo ""; fatal "配置校验失败。请修复 .env 文件，或删除后重新运行 ./animosaas。"; }
  success "配置校验通过"
}

check_volume_conflict() {
  local project_name
  project_name=$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]//g')
  local full_volume="${project_name}_postgres_data"

  if docker volume inspect "$full_volume" &>/dev/null 2>&1; then
    echo ""
    warn "检测到已有数据库数据卷: ${BOLD}${full_volume}${NC}"
    echo ""
    printf "    %bPostgreSQL 会在首次启动时将密码固化到数据卷中。%b\n" "${YELLOW}" "${NC}"
    printf "    %b如果 .env 中的 DB_PASSWORD 与卷内密码不一致，将导致认证失败。%b\n" "${YELLOW}" "${NC}"
    echo ""
    if confirm "是否清除旧数据卷并重新初始化？（数据将丢失）" "y"; then
      spinner_start "正在清除旧容器和数据卷..."
      compose down -v --remove-orphans 2>/dev/null || true
      spinner_stop
      success "旧数据已清除"
    else
      echo ""
      info "已保留旧数据卷。如遇认证错误，请运行 ${BOLD}./animosaas reset${NC}"
    fi
  fi
}

deploy() {
  # ── Pull or Build image ──
  if [[ "$BUILD_LOCAL" -eq 1 ]]; then
    step "构建" "正在本地构建 Docker 镜像..."
    spinner_start "正在构建镜像（首次构建可能需要几分钟）..."

    local build_output
    if build_output=$(compose build --no-cache 2>&1); then
      spinner_stop
      success "本地镜像构建完成"
    else
      spinner_stop
      error "镜像构建失败"
      if [[ "$VERBOSE" -eq 1 ]]; then echo "$build_output"
      else echo "$build_output" | tail -10; info "添加 ${BOLD}--verbose${NC} 参数可查看完整构建日志"
      fi
      exit 1
    fi
  else
    step "拉取" "正在拉取预构建 Docker 镜像..."
    spinner_start "正在拉取镜像 ${DOCKER_IMAGE}..."

    local pull_output
    if pull_output=$(compose pull 2>&1); then
      spinner_stop
      success "镜像拉取完成"
    else
      spinner_stop
      warn "预构建镜像拉取失败，尝试本地构建..."
      if [[ -f "Dockerfile" ]]; then
        BUILD_LOCAL=1
        spinner_start "正在本地构建镜像..."
        if build_output=$(compose build --no-cache 2>&1); then
          spinner_stop
          success "本地镜像构建完成"
        else
          spinner_stop
          error "镜像构建也失败了"
          echo "$build_output" | tail -10
          exit 1
        fi
      else
        fatal "镜像拉取失败且无 Dockerfile 可用于本地构建"
      fi
    fi
  fi

  # ── Start services ──
  step "启动" "正在启动服务..."
  spinner_start "正在启动容器..."

  local up_env=""
  if [[ -n "$_WIZARD_SUPER_PASSWORD" ]]; then
    env SUPER_ADMIN_PASSWORD="${_WIZARD_SUPER_PASSWORD}" compose up -d 2>/dev/null
  else
    compose up -d 2>/dev/null
  fi
  spinner_stop
  success "容器已启动"

  # ── Health check with progress ──
  step "就绪" "等待服务就绪..."

  local max_wait=$HEALTH_TIMEOUT elapsed=0 status="starting"

  while [[ $elapsed -lt $max_wait ]]; do
    status=$(docker inspect --format='{{.State.Health.Status}}' "$CONTAINER_APP" 2>/dev/null || echo "starting")
    [[ "$status" == "healthy" ]] && break

    if [[ $elapsed -ge 30 ]]; then
      local restart_count
      restart_count=$(docker inspect --format='{{.RestartCount}}' "$CONTAINER_APP" 2>/dev/null || echo "0")
      if [[ "$restart_count" -ge 5 ]] 2>/dev/null; then
        printf "\r\033[K"
        error "容器持续崩溃重启（已重启 ${restart_count} 次）"
        status="crash-loop"; break
      fi
    fi

    progress_bar "$elapsed" "$max_wait"
    printf " %b%s%b" "${DIM}" "${status}" "${NC}"
    sleep 5; elapsed=$((elapsed + 5))
  done
  printf "\r\033[K"

  if [[ "$status" == "healthy" ]]; then
    print_deploy_success
    return 0
  else
    print_deploy_failure "$max_wait"
    return 1
  fi
}

