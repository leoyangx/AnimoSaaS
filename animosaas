# ══════════════════════════════════════════════════════════════
#  CURL | BASH BOOTSTRAP
# ══════════════════════════════════════════════════════════════
# When run via `curl ... | bash`, BASH_SOURCE is empty.
# Clone the repo first, then re-execute the local copy.

if [[ -z "${BASH_SOURCE[0]:-}" ]] || [[ "${BASH_SOURCE[0]}" == "bash" ]] || [[ "${BASH_SOURCE[0]}" == "/dev/stdin" ]] || [[ "${BASH_SOURCE[0]}" == "-" ]]; then
  _PIPED=1

  # Minimal color for bootstrap phase
  if [[ -t 1 ]] 2>/dev/null && [[ "${TERM:-}" != "dumb" ]]; then
    _B='\033[1m'; _C='\033[0;36m'; _G='\033[0;32m'; _R='\033[0;31m'; _Y='\033[1;33m'; _N='\033[0m'
  else
    _B=''; _C=''; _G=''; _R=''; _Y=''; _N=''
  fi

  printf "\n%b" "${_C}"
  cat << 'BANNER'
       _          _                 ____              ____
      / \   _ __ (_)_ __ ___   ___/ ___|  __ _  __ _/ ___|
     / _ \ | '_ \| | '_ ` _ \ / _ \___ \ / _` |/ _` \___ \
    / ___ \| | | | | | | | | | (_) |__) | (_| | (_| |___) |
   /_/   \_\_| |_|_|_| |_| |_|\___/____/ \__,_|\__,_|____/
BANNER
  printf "%b\n" "${_N}"
  printf "  %b一键安装模式%b  v%s\n\n" "${_B}" "${_N}" "${ANIMOSAAS_VERSION}"

  # ── 依赖检测 & 自动安装 Docker ──
  if ! command -v git &>/dev/null; then
    printf "  %b▸%b 正在安装 Git...\n" "${_C}" "${_N}"
    if command -v apt-get &>/dev/null; then
      sudo apt-get update -qq && sudo apt-get install -y -qq git
    elif command -v yum &>/dev/null; then
      sudo yum install -y -q git
    elif command -v dnf &>/dev/null; then
      sudo dnf install -y -q git
    else
      printf "  %b✘ 无法自动安装 Git，请手动安装%b\n" "${_R}" "${_N}"
      exit 1
    fi
    printf "  %b✔%b Git 安装完成\n" "${_G}" "${_N}"
  fi

  if ! command -v docker &>/dev/null; then
    printf "  %b▸%b Docker 未安装，正在自动安装...\n" "${_C}" "${_N}"
    curl -fsSL https://get.docker.com | bash
    sudo systemctl start docker 2>/dev/null || true
    sudo systemctl enable docker 2>/dev/null || true
    printf "  %b✔%b Docker 安装完成\n" "${_G}" "${_N}"
  fi

  if ! docker compose version &>/dev/null 2>&1 && ! command -v docker-compose &>/dev/null; then
    printf "  %b✘ Docker Compose 不可用%b\n" "${_R}" "${_N}"
    printf "    请升级 Docker 至最新版本以获得 compose 插件\n"
    exit 1
  fi

  # ── 克隆或更新仓库 ──
  _target="${INSTALL_DIR}"
  printf "  %b▸%b 安装目录: %b%s%b\n" "${_C}" "${_N}" "${_B}" "${_target}" "${_N}"

  if [[ -d "${_target}/.git" ]]; then
    printf "  %b✔%b 检测到已有安装，拉取最新代码...\n" "${_G}" "${_N}"
    cd "${_target}"
    git pull origin main 2>/dev/null || true
  else
    printf "  %b▸%b 正在克隆仓库...\n" "${_C}" "${_N}"
    mkdir -p "$(dirname "${_target}")" 2>/dev/null || sudo mkdir -p "$(dirname "${_target}")"
    if [[ -w "$(dirname "${_target}")" ]]; then
      git clone "${REPO_URL}" "${_target}" 2>/dev/null
    else
      sudo git clone "${REPO_URL}" "${_target}" 2>/dev/null
      sudo chown -R "$(id -u):$(id -g)" "${_target}"
    fi
    cd "${_target}"
    printf "  %b✔%b 仓库克隆完成\n" "${_G}" "${_N}"
  fi

  chmod +x "${_target}/animosaas"
  printf "  %b▸%b 正在启动安装向导...\n\n" "${_C}" "${_N}"
  exec "${_target}/animosaas" "$@"
  exit 0
fi

