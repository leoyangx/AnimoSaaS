# ── 6. Status ──

do_status() {
  echo ""
  printf "  %b服务运行概览%b\n" "${BOLD}" "${NC}"
  echo ""

  printf "  %b%-24s %-12s %-12s %-10s%b\n" "${BOLD}" "容器" "运行状态" "健康状态" "运行时长" "${NC}"
  printf "  %b────────────────────────────────────────────────────────────%b\n" "${DIM}" "${NC}"

  for container in "$CONTAINER_DB" "$CONTAINER_APP"; do
    local status health uptime_raw
    status=$(docker inspect --format='{{.State.Status}}' "$container" 2>/dev/null || echo "未找到")
    health=$(docker inspect --format='{{.State.Health.Status}}' "$container" 2>/dev/null || echo "-")
    uptime_raw=$(docker inspect --format='{{.State.StartedAt}}' "$container" 2>/dev/null || echo "-")

    local color="$RED"; [[ "$status" == "running" ]] && color="$GREEN"

    local uptime_str="-"
    if [[ "$status" == "running" && "$uptime_raw" != "-" ]]; then
      local started_epoch now_epoch diff_sec
      started_epoch=$(date -d "$uptime_raw" +%s 2>/dev/null || date -j -f "%Y-%m-%dT%H:%M:%S" "${uptime_raw%%.*}" +%s 2>/dev/null || echo "0")
      now_epoch=$(date +%s)
      if [[ "$started_epoch" -gt 0 ]]; then
        diff_sec=$((now_epoch - started_epoch))
        if [[ $diff_sec -lt 60 ]]; then uptime_str="${diff_sec}秒"
        elif [[ $diff_sec -lt 3600 ]]; then uptime_str="$((diff_sec / 60))分钟"
        elif [[ $diff_sec -lt 86400 ]]; then uptime_str="$((diff_sec / 3600))时$((diff_sec % 3600 / 60))分"
        else uptime_str="$((diff_sec / 86400))天$((diff_sec % 86400 / 3600))时"
        fi
      fi
    fi

    local health_color="$DIM"
    [[ "$health" == "healthy" ]] && health_color="$GREEN"
    [[ "$health" == "unhealthy" ]] && health_color="$RED"

    printf "  %-24s %b%-12s%b %b%-12s%b %-10s\n" \
      "$container" "$color" "$status" "$NC" "$health_color" "$health" "$NC" "$uptime_str"
  done
  echo ""

  printf "  %b资源使用:%b\n" "${BOLD}" "${NC}"
  docker stats --no-stream --format "  {{.Name}}    CPU: {{.CPUPerc}}    内存: {{.MemUsage}}" \
    "$CONTAINER_APP" "$CONTAINER_DB" 2>/dev/null || warn "无法获取资源信息"
  echo ""

  local app_port; app_port=$(read_env_value "APP_PORT"); app_port="${app_port:-3000}"
  printf "  %b健康检查:%b " "${BOLD}" "${NC}"
  local health_resp
  health_resp=$(curl -sf "http://localhost:${app_port}/api/health" 2>/dev/null) && {
    command -v python3 &>/dev/null && echo "$health_resp" | python3 -m json.tool 2>/dev/null || echo "$health_resp"
  } || printf "%b无法连接%b\n" "${RED}" "${NC}"

  press_enter
}

# ── 7. Change Port ──

do_change_port() {
  echo ""
  local current_port; current_port=$(read_env_value "APP_PORT"); current_port="${current_port:-3000}"
  printf "  当前端口: %b%s%b\n" "${BOLD}" "${current_port}" "${NC}"
  printf "  %b输入新端口%b: " "${CYAN}" "${NC}"
  read -r new_port </dev/tty

  [[ -z "$new_port" ]] && { info "未输入，已取消"; press_enter; return; }
  if ! [[ "$new_port" =~ ^[0-9]+$ ]] || [[ "$new_port" -lt 1 ]] || [[ "$new_port" -gt 65535 ]]; then
    error "无效的端口号（1-65535）"; press_enter; return
  fi

  set_env_value "APP_PORT" "$new_port"
  local current_url; current_url=$(read_env_value "APP_URL")
  if [[ "$current_url" == *":${current_port}"* ]]; then
    set_env_value "APP_URL" "${current_url/:${current_port}/:${new_port}}"
    success "APP_URL 已同步更新"
  fi
  success "端口已更新为: ${new_port}"

  if confirm "是否立即重启服务使更改生效？" "y"; then
    compose down 2>/dev/null; compose up -d 2>/dev/null
    success "服务已使用新端口重启"
  else
    warn "请手动重启服务使更改生效"
  fi
  press_enter
}

