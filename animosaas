# ── Deploy Failure ──

print_deploy_failure() {
  local max_wait="$1"
  echo ""
  printf "  %b" "${RED}"
  cat << 'EOF'
  ┌───────────────────────────────────────────────┐
  │                                               │
  │             部署失败                           │
  │                                               │
  └───────────────────────────────────────────────┘
EOF
  printf "  %b" "${NC}"
  printf "  %b服务在 %d 秒内未能正常启动%b\n" "${RED}" "$max_wait" "${NC}"
  echo ""

  step "诊断" "正在收集诊断信息..."
  echo ""

  printf "  %b%-16s%b " "${BOLD}" "数据库:" "${NC}"
  docker inspect --format='状态={{.State.Status}} 健康={{.State.Health.Status}}' "$CONTAINER_DB" 2>/dev/null || printf "容器不存在"
  echo ""

  printf "  %b%-16s%b " "${BOLD}" "应用:" "${NC}"
  docker inspect --format='状态={{.State.Status}} 重启次数={{.RestartCount}}' "$CONTAINER_APP" 2>/dev/null || printf "容器不存在"
  echo ""; echo ""

  printf "  %b── 最近的应用日志 ──%b\n" "${YELLOW}" "${NC}"
  compose logs app --tail 20 2>/dev/null || true
  echo ""

  printf "  %b── 自动诊断 ──%b\n" "${BOLD}" "${NC}"
  local app_logs
  app_logs=$(compose logs app --tail 50 2>/dev/null || true)

  if echo "$app_logs" | grep -qi "Authentication failed\|P1000\|password authentication failed"; then
    error "检测到数据库认证失败"
    printf "    %b原因: .env 中的 DB_PASSWORD 与数据卷内的密码不一致%b\n" "${YELLOW}" "${NC}"
    printf "    %b修复: ./animosaas reset%b\n" "${YELLOW}" "${NC}"
  elif echo "$app_logs" | grep -qi "ECONNREFUSED\|Connection refused"; then
    error "检测到数据库连接被拒绝"
    printf "    %b原因: 数据库容器可能未正常启动%b\n" "${YELLOW}" "${NC}"
    printf "    %b修复: $COMPOSE_CMD logs db%b\n" "${YELLOW}" "${NC}"
  elif echo "$app_logs" | grep -qi "JWT_SECRET\|Missing.*environment"; then
    error "检测到环境变量缺失"
    printf "    %b修复: 检查 .env 文件完整性，或删除后重新运行 ./animosaas%b\n" "${YELLOW}" "${NC}"
  else
    warn "未匹配到已知错误模式，请查看上方日志排查"
  fi

  echo ""
  printf "  %b手动排查:%b\n" "${BOLD}" "${NC}"
  printf "    完整日志:    %b$COMPOSE_CMD logs app%b\n" "${DIM}" "${NC}"
  printf "    进入容器:    %bdocker exec -it %s bash%b\n" "${DIM}" "$CONTAINER_APP" "${NC}"
  printf "    完全重置:    %b./animosaas reset%b\n" "${DIM}" "${NC}"
  echo ""
}

