  printf "  %b修改超级管理员密码%b\n" "${BOLD}" "${NC}"
  echo ""

  local app_status
  app_status=$(docker inspect --format='{{.State.Status}}' "$CONTAINER_APP" 2>/dev/null || echo "stopped")
  if [[ "$app_status" != "running" ]]; then
    error "应用容器未运行，请先启动服务"; press_enter; return
  fi

  printf "  %b输入新密码%b (至少 12 位，含大小写字母和数字): " "${CYAN}" "${NC}"
  read -rs new_password </dev/tty; echo ""
  [[ -z "$new_password" ]] && { info "未输入，已取消"; press_enter; return; }
  [[ ${#new_password} -lt 12 ]] && { error "密码长度至少 12 位"; press_enter; return; }

  printf "  %b确认新密码%b: " "${CYAN}" "${NC}"
  read -rs confirm_password </dev/tty; echo ""
  [[ "$new_password" != "$confirm_password" ]] && { error "两次输入的密码不一致"; press_enter; return; }

  info "正在更新超级管理员密码..."

  local update_result
  update_result=$(docker exec -e "ANIMOSAAS_NEW_PW=${new_password}" "$CONTAINER_APP" node -e "
    const bcrypt = require('bcryptjs');
    const { PrismaClient } = require('@prisma/client');
    const prisma = new PrismaClient();
    (async () => {
      try {
        const hash = await bcrypt.hash(process.env.ANIMOSAAS_NEW_PW, 12);
        const result = await prisma.superAdmin.updateMany({
          data: { password: hash }
        });
        console.log('OK:' + result.count);
      } catch(e) {
        console.error('ERROR:' + e.message);
        process.exit(1);
      } finally {
        await prisma.\$disconnect();
      }
    })();
  " 2>&1)

  if echo "$update_result" | grep -q "^OK:"; then
    local count; count=$(echo "$update_result" | grep "^OK:" | cut -d: -f2)
    success "超级管理员密码已更新（影响 ${count} 个账号）"
    echo ""
    printf "  %b请使用新密码重新登录超级管理后台。%b\n" "${YELLOW}" "${NC}"
  else
    error "密码更新失败: ${update_result}"
  fi
  press_enter
}

# ── 10. HTTPS Certificate ──

do_https() {
  echo ""
  printf "  %b自动申请/续期 HTTPS 证书%b\n" "${BOLD}" "${NC}"
  echo ""

  if ! command_exists certbot; then
    warn "certbot 未安装"
    echo ""
    printf "  %b安装方法:%b\n" "${BOLD}" "${NC}"
    printf "    Ubuntu/Debian:  %bsudo apt install certbot%b\n" "${DIM}" "${NC}"
    printf "    CentOS/RHEL:    %bsudo yum install certbot%b\n" "${DIM}" "${NC}"
    printf "    通用:           %bsudo snap install --classic certbot%b\n" "${DIM}" "${NC}"
    press_enter; return
  fi

  local current_url default_domain=""
  current_url=$(read_env_value "APP_URL")
  [[ -n "$current_url" ]] && default_domain=$(echo "$current_url" | sed -E 's|https?://||' | sed 's|/.*||' | sed 's|:.*||')

  printf "  %b输入域名%b [%s]: " "${CYAN}" "${NC}" "${default_domain:-example.com}"
  read -r domain </dev/tty
  domain="${domain:-$default_domain}"
  if [[ -z "$domain" ]] || [[ "$domain" == "localhost" ]]; then
    error "请输入有效的域名（不能是 localhost）"; press_enter; return
  fi

  printf "  %b输入邮箱%b (用于 Let's Encrypt 通知): " "${CYAN}" "${NC}"
  read -r email </dev/tty
  [[ -z "$email" ]] && { error "邮箱不能为空"; press_enter; return; }

  echo ""
  printf "  %b" "${YELLOW}"
  printf "  ┌──────────────────────────────────────────────────────┐\n"
  printf "  │  ⚠  请确保 80 和 443 端口已开放且未被占用           │\n"
  printf "  │     域名 DNS 必须指向本服务器 IP                     │\n"
  printf "  └──────────────────────────────────────────────────────┘\n"
  printf "  %b" "${NC}"
  echo ""

  info "正在为 ${domain} 申请证书..."
  if sudo certbot certonly --standalone \
    -d "$domain" --email "$email" \
    --agree-tos --non-interactive \
    --preferred-challenges http 2>&1; then
    echo ""
    success "证书申请成功！"
    echo ""
    printf "  %b证书路径:%b\n" "${BOLD}" "${NC}"
    printf "    证书: /etc/letsencrypt/live/%s/fullchain.pem\n" "$domain"
    printf "    私钥: /etc/letsencrypt/live/%s/privkey.pem\n" "$domain"
    echo ""
    if confirm "是否将 APP_URL 更新为 https://${domain}？" "y"; then
      set_env_value "APP_URL" "https://${domain}"
      success "APP_URL 已更新"
      warn "请配置反向代理（如 Nginx）以使用 HTTPS 证书"
    fi
  else
    error "证书申请失败，请检查域名 DNS 是否正确指向本服务器"
  fi
  press_enter
}

# ── 11. Backup ──

do_backup() {
  echo ""
  info "正在创建数据库备份..."
  local timestamp backup_file
  timestamp=$(date '+%Y%m%d_%H%M%S')
  backup_file="backups/animosaas_${timestamp}.sql.gz"
  mkdir -p backups

  if docker exec "$CONTAINER_DB" pg_dump -U animosaas animosaas_db 2>/dev/null | gzip > "$backup_file"; then
    local size; size=$(du -h "$backup_file" 2>/dev/null | cut -f1)
    success "备份已保存: ${backup_file}（${size}）"
  else
    rm -f "$backup_file"
    error "备份失败，请确认数据库容器正在运行"
  fi
  press_enter
}

do_backup_silent() {
  local timestamp backup_file
  timestamp=$(date '+%Y%m%d_%H%M%S')
  backup_file="backups/animosaas_pre_upgrade_${timestamp}.sql.gz"
  mkdir -p backups
  info "正在备份数据库..."
  if docker exec "$CONTAINER_DB" pg_dump -U animosaas animosaas_db 2>/dev/null | gzip > "$backup_file"; then
    local size; size=$(du -h "$backup_file" 2>/dev/null | cut -f1)
    success "备份已保存: ${backup_file}（${size}）"
  else
    rm -f "$backup_file"
    warn "备份失败（将继续升级）"
  fi
}

# ── 12. Restore ──

do_restore() {
  echo ""
  printf "  %b恢复数据库备份%b\n" "${BOLD}" "${NC}"
  echo ""

  if [[ ! -d backups ]] || [[ -z "$(ls -A backups/ 2>/dev/null)" ]]; then
    warn "backups/ 目录为空，没有可用的备份文件"; press_enter; return
  fi

  printf "  %b可用备份:%b\n" "${BOLD}" "${NC}"
  local i=1 files=()
  while IFS= read -r file; do
    local fsize fname
    fsize=$(du -h "$file" 2>/dev/null | cut -f1)
    fname=$(basename "$file")
    printf "    %b%d.%b  %s  (%s)\n" "${BOLD}" "$i" "${NC}" "$fname" "$fsize"
    files+=("$file"); i=$((i + 1))
  done < <(ls -t backups/*.sql.gz 2>/dev/null)

  [[ ${#files[@]} -eq 0 ]] && { warn "没有找到 .sql.gz 备份文件"; press_enter; return; }

  echo ""
  printf "  %b选择要恢复的备份编号%b (0 取消): " "${CYAN}" "${NC}"
  read -r choice </dev/tty
  [[ -z "$choice" || "$choice" == "0" ]] && { info "已取消"; press_enter; return; }
  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt ${#files[@]} ]]; then
    error "无效的选择"; press_enter; return
  fi

  local selected_file="${files[$((choice - 1))]}"
  echo ""
  printf "  %b" "${RED}"
  printf "  ┌──────────────────────────────────────────────────────┐\n"
  printf "  │  ⚠  警告：恢复操作将覆盖当前数据库所有数据！        │\n"
  printf "  └──────────────────────────────────────────────────────┘\n"
  printf "  %b" "${NC}"

  if ! confirm "确认恢复 $(basename "$selected_file")？" "n"; then
    info "已取消恢复"; press_enter; return
  fi

  info "正在恢复数据库..."
  if gunzip -c "$selected_file" | docker exec -i "$CONTAINER_DB" psql -U animosaas -d animosaas_db 2>/dev/null; then
    success "数据库已恢复: $(basename "$selected_file")"
    echo ""; warn "建议重启应用服务以清除缓存"
    if confirm "是否立即重启？" "y"; then
      compose restart app 2>/dev/null; success "应用已重启"
    fi
  else
    error "恢复失败，请检查备份文件完整性"
  fi
  press_enter
}

# ── 13. Upgrade ──

do_upgrade() {
  echo ""
  printf "  %b一键升级%b\n" "${BOLD}" "${NC}"
  echo ""

  [[ ! -d .git ]] && { error "非 Git 仓库，无法执行升级"; press_enter; return; }

  if confirm "升级前是否先备份数据库？（推荐）" "y"; then
    do_backup_silent
  fi

  echo ""
  info "步骤 1/4: 拉取最新代码..."
  if ! git pull origin main 2>/dev/null; then
    error "代码拉取失败，请检查网络或解决合并冲突"; press_enter; return
  fi
  success "代码已更新"

  info "步骤 2/4: 停止服务..."
  compose down 2>/dev/null
  success "服务已停止"

  if [[ "$BUILD_LOCAL" -eq 1 ]]; then
    info "步骤 3/4: 重新构建镜像..."
    if ! compose build --no-cache 2>/dev/null; then
      error "构建失败，请检查构建日志"
      printf "  查看日志: %b$COMPOSE_CMD logs%b\n" "${DIM}" "${NC}"
      press_enter; return
    fi
    success "镜像构建完成"
  else
    info "步骤 3/4: 拉取最新镜像..."
    if compose pull 2>/dev/null; then
      success "镜像拉取完成"
    else
      warn "镜像拉取失败，尝试本地构建..."
      if [[ -f "Dockerfile" ]]; then
        compose build --no-cache 2>/dev/null || { error "构建也失败了"; press_enter; return; }
        success "本地构建完成"
      else
        error "无法更新镜像"; press_enter; return
      fi
    fi
  fi

  info "步骤 4/4: 启动服务..."
  compose up -d 2>/dev/null
  success "服务已启动"

  echo ""
  success "升级完成！"
  press_enter
}

# ── 14. Reinstall ──

do_reinstall() {
  echo ""
  printf "  %b" "${YELLOW}${BOLD}"
  cat << 'EOF'
  ┌──────────────────────────────────────────────────────┐
  │                                                      │
  │   重新安装 AnimoSaaS                                 │
  │                                                      │
  │   此操作将：                                         │
  │   · 停止所有服务                                     │
  │   · 删除 .env 配置文件                               │
  │   · 重新运行安装向导                                 │
  │                                                      │
  │   注意：数据库数据卷将保留（除非选择清除）           │
  │                                                      │
  └──────────────────────────────────────────────────────┘
EOF
  printf "  %b" "${NC}"
  echo ""

  if ! confirm "确认要重新安装？" "n"; then
    info "已取消"; press_enter; return
  fi

  info "正在停止服务..."
  compose down 2>/dev/null || true
  rm -f .env
  success "配置已清除"

  echo ""
  info "正在启动安装向导..."
  sleep 1
  run_install
}

# ── 15. Reset ──

do_reset() {
  echo ""
  printf "  %b" "${RED}${BOLD}"
  cat << 'EOF'
  ┌──────────────────────────────────────────────────────┐
  │                                                      │
  │   ⚠  危险操作：完全重置系统 ⚠                       │
  │                                                      │
  │   此操作将：                                         │
  │   · 停止并移除所有容器                               │
  │   · 删除数据库数据卷（全部数据将丢失）               │
  │   · 删除 .env 配置文件                               │
  │   · 需要重新运行安装向导                             │
  │                                                      │
  │   此操作不可逆！请确保已备份重要数据！               │
  │                                                      │
  └──────────────────────────────────────────────────────┘
EOF
  printf "  %b" "${NC}"
  echo ""

  printf "  输入 %bYES%b 确认重置（区分大小写）: " "${BOLD}${RED}" "${NC}" >&2
  read -r confirm_input </dev/tty
  [[ "$confirm_input" != "YES" ]] && { info "已取消重置"; press_enter; return; }

  printf "  %b再次确认：输入 %bRESET%b 执行重置: %b" "${RED}" "${BOLD}" "${NC}${RED}" "${NC}" >&2
  read -r confirm_input2 </dev/tty
  [[ "$confirm_input2" != "RESET" ]] && { info "已取消重置"; press_enter; return; }

  echo ""
  info "正在移除容器和数据卷..."
  compose down -v --remove-orphans 2>/dev/null || true
  info "正在删除配置文件..."
  rm -f .env

  success "系统已重置"
  echo ""
  info "运行 ${BOLD}./animosaas${NC} 重新开始安装向导。"
  echo ""
  exit 0
}

