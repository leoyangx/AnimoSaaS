# ── 1. Version & Update Check ──

do_version_check() {
  echo ""
  printf "  %b版本信息%b\n" "${BOLD}" "${NC}"
  echo ""
  printf "  当前版本: %bv%s%b\n" "${GREEN}" "${ANIMOSAAS_VERSION}" "${NC}"

  if [[ -d .git ]]; then
    local current_branch current_commit
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    current_commit=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    printf "  当前分支: %b%s%b\n" "${CYAN}" "${current_branch}" "${NC}"
    printf "  当前提交: %b%s%b\n" "${DIM}" "${current_commit}" "${NC}"
    echo ""

    info "正在检查远程更新..."
    git fetch origin 2>/dev/null || { warn "无法连接远程仓库"; press_enter; return; }

    local local_hash remote_hash
    local_hash=$(git rev-parse HEAD 2>/dev/null)
    remote_hash=$(git rev-parse "origin/${current_branch}" 2>/dev/null || echo "")

    if [[ -z "$remote_hash" ]]; then
      warn "无法获取远程分支信息"
    elif [[ "$local_hash" == "$remote_hash" ]]; then
      success "已是最新版本"
    else
      local behind_count
      behind_count=$(git rev-list --count HEAD.."origin/${current_branch}" 2>/dev/null || echo "?")
      warn "发现 ${behind_count} 个新提交可更新"
      echo ""
      printf "  %b最近更新日志:%b\n" "${BOLD}" "${NC}"
      git log --oneline HEAD.."origin/${current_branch}" 2>/dev/null | head -10 | while read -r line; do
        printf "    %b•%b %s\n" "${CYAN}" "${NC}" "$line"
      done
      echo ""
      info "选择菜单 [13] 或运行 ${BOLD}./animosaas upgrade${NC} 执行升级"
    fi
  else
    warn "非 Git 仓库，无法检查更新"
  fi
  press_enter
}

